      "position": [
        430,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const activeCampaigns = [];\nconst currentAccount = $node[\"Webhook Trigger (account.restricted)\"].json[\"body\"][\"data\"][\"id\"];\n\nfor (const item of $input.all()) {\n  const campaign = item.json;\n  // If campaign uses the restricted account in its pool, stage for pausing\n  if (campaign.status === 'active' && campaign.account_ids && campaign.account_ids.includes(currentAccount)) {\n    activeCampaigns.push({ json: { id: campaign.id, name: campaign.name } });\n  }\n}\nreturn activeCampaigns;"
      },
      "id": "2db41cd2-e889-42b7-a3cf-fb25a89f921d",
      "name": "Filter Campaigns Using Account",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=={{ $env.PHANTOM_X_API_URL }}/campaigns/{{ $json[\"id\"] }}/pause",
