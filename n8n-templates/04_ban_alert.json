        "jsonBody": "={\"name\":\"🔥 URGENT: Recover Restricted LinkedIn Account [{{ $node[\"Webhook Trigger (account.restricted)\"].json[\"body\"][\"data\"][\"label\"] }}]\",\"description\":\"The LinkedIn account has been flagged as restricted. Immediate mitigation, verification of proxy country ({{ $node[\"Webhook Trigger (account.restricted)\"].json[\"body\"][\"data\"][\"proxy_country\"] }}), and cookie refreshes are required.\",\"priority\":1,\"status\":\"to do\"}",
