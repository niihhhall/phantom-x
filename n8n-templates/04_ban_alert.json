    {
      "parameters": {
        "channel": "={{ $env.SLACK_CHANNEL }}",
        "text": "=🚨 *CRITICAL: LinkedIn Account Restricted!* 🚨\n• *Account Label*: `{{ $node[\"Webhook Trigger (account.restricted)\"].json[\"body\"][\"data\"][\"label\"] }}`\n• *Proxy Country*: `{{ $node[\"Webhook Trigger (account.restricted)\"].json[\"body\"][\"data\"][\"proxy_country\"] }}`\n• *Safety Score*: `{{ $node[\"Webhook Trigger (account.restricted)\"].json[\"body\"][\"data\"][\"safety_score\"] }}%`\n• *Actions Taken*: Automatically paused all active campaigns associated with this account pool to protect prospect safety.",
        "otherOptions": {
          "mrkdwn": true
        }
      },
      "id": "8fa1cd2b-fcda-492a-a9fa-98fa98ebcf21",
